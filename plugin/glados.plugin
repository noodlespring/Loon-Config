#!name = GLaDOS 自动签到
#!desc = 每天自动签到；Cookie 与订阅链接由 Safari 访问时自动捕获；通知中显示剩余天数 + 积分 + 流量用量
#!author = noodlespring
#!icon = https://glados.cloud/favicon.ico
#!homepage = https://github.com/noodlespring/Loon-Config

[Script]
http-request ^https?:\/\/glados\.cloud\/api\/user\/(status|checkin) requires-body=false, script-path=https://raw.githubusercontent.com/noodlespring/Loon-Config/main/script/glados-cookie.js, tag=GLaDOS-Cookie捕获, timeout=10

http-request ^https?:\/\/glados\.cloud\/subscribe\/ requires-body=false, script-path=https://raw.githubusercontent.com/noodlespring/Loon-Config/main/script/glados-sub.js, tag=GLaDOS-订阅捕获, timeout=10

cron "5 9 * * *" script-path=https://raw.githubusercontent.com/noodlespring/Loon-Config/main/script/glados-checkin.js, tag=GLaDOS签到, timeout=30

[MITM]
hostname = glados.cloud
